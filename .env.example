# ====================================
# Claude Phone Configuration
# ====================================
# Copy this to .env and fill in your values

# ====================================
# Network Configuration
# ====================================

# Your server's LAN IP (CRITICAL for RTP audio)
# This IP goes into SDP packets so 3CX knows where to send audio
EXTERNAL_IP=10.0.0.100

# Optional: source-of-truth directory mounted at /app/config in the voice-app container.
# For generic/local use, keep the repo default. For Hermes, this can point at a tracked
# homelab-infrastructure directory instead of the ignored local voice-app/config path.
DEVICE_CONFIG_DIR=./voice-app/config

# SIP address drachtio advertises in dialog Contact headers.
# For the Hermes+Asterisk local-trunk topology, keep this on 127.0.0.1.
# For direct/public deployments, this should normally match EXTERNAL_IP.
DRACHTIO_EXTERNAL_IP=10.0.0.100

# ====================================
# Drachtio Configuration
# ====================================

DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=replace-with-random-secret

# SIP port for Contact header (5070 for 3CX SBC mode, 5060 for direct registration)
# This MUST match the port in docker-compose.yml drachtio command
DRACHTIO_SIP_PORT=5060

# ====================================
# FreeSWITCH Configuration
# ====================================

FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_SECRET=replace-with-random-secret

# ====================================
# 3CX / SIP Configuration
# ====================================

# Your 3CX server hostname or IP
SIP_DOMAIN=your-3cx-server.3cx.us
SIP_REGISTRAR=10.0.0.50

# Default extension for outbound calls
SIP_EXTENSION=9000
SIP_AUTH_ID=your-auth-id
SIP_AUTH_PASSWORD=your-password

# Default caller ID for outbound PSTN calls
DEFAULT_CALLER_ID=+15551234567

# SIP trunk or PBX host for outbound calls initiated by claude-phone
SIP_TRUNK_HOST=127.0.0.1

# ====================================
# Claude API Server
# ====================================

# URL to your Claude API server (runs on your API server with Claude Max)
CLAUDE_API_URL=http://10.0.0.200:3333

# Optional: bind claude-api-server to localhost or a specific interface
CLAUDE_API_BIND_HOST=127.0.0.1

# Optional: shared token between voice-app and claude-api-server
CLAUDE_API_TOKEN=replace-with-random-token

# Claude CLI working directory and profile behavior
CLAUDE_WORKING_DIR=/home/alborz
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_PERMISSION_MODE=bypassPermissions

# Safer defaults for live phone calls
PHONE_CLAUDE_MODEL=haiku
PHONE_HAIKU_CLAUDE_MODEL=haiku
PHONE_SONNET_CLAUDE_MODEL=sonnet
PHONE_OPUS_CLAUDE_MODEL=opus
PHONE_CLAUDE_PERMISSION_MODE=dontAsk
# Optional: restrict phone-call tools further, e.g. Read,Grep,Glob,LS
# PHONE_CLAUDE_ALLOWED_TOOLS=

# ====================================
# TTS - Kokoro or Any OpenAI-Compatible Speech API
# ====================================

TTS_BASE_URL=http://127.0.0.1:18000/v1
TTS_API_KEY=not-needed
TTS_MODEL=kokoro
TTS_VOICE=af_bella
TTS_RESPONSE_FORMAT=mp3

# ====================================
# STT - Whisper or Any OpenAI-Compatible Transcription API
# ====================================

STT_BASE_URL=http://127.0.0.1:18001/v1
STT_API_KEY=not-needed
STT_MODEL=whisper-1

# ====================================
# Application Settings
# ====================================

# HTTP server port for API and audio file serving
HTTP_HOST=127.0.0.1
HTTP_PORT=3000

# WebSocket port for audio streaming from FreeSWITCH
WS_HOST=127.0.0.1
WS_PORT=3001

# Audio files directory
AUDIO_DIR=/app/audio

# ====================================
# Outbound Call Settings
# ====================================

# Maximum conversation turns for outbound calls
MAX_CONVERSATION_TURNS=10

# Ring timeout in seconds
OUTBOUND_RING_TIMEOUT=30

# ====================================
# Optional: Debug
# ====================================

# DEBUG=voice-app:*
